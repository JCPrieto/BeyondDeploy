#!/bin/sh
set -e

case "$1" in
  configure)
    ln -sf /opt/beyonddeploy/bin/BeyondDeploy /usr/bin/beyonddeploy

    DESKTOP_SRC="/opt/beyonddeploy/lib/beyonddeploy-BeyondDeploy.desktop"
    DESKTOP_DST="/usr/share/applications/es-jklabs-BeyondDeploy.desktop"

    if [ -f "$DESKTOP_SRC" ]; then
      install -D -m 0644 "$DESKTOP_SRC" "$DESKTOP_DST" || true
    fi

    command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database -q || true
  ;;
esac

exit 0
